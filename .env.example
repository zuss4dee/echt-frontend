# Copy to `.env.local` and fill in for the main app (document upload / Supabase).
# Not required for marketing routes like `/landing`.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard → Auth → URL Configuration
# Redirect URL (allow list): https://useecht.com/auth/callback (and http://localhost:3000/auth/callback for dev)
# Post-Whop landing on /login?checkout=success does not need to be in this list unless you use /login as Supabase redirectTo.

# Canonical site URL (used to append post-checkout return URL to hosted Whop checkout links)
# NEXT_PUBLIC_APP_URL=https://www.useecht.com

# Whop hosted checkout: primary success-redirect param (default: redirect_url; code also adds onSuccess)
# NEXT_PUBLIC_WHOP_CHECKOUT_SUCCESS_PARAM=redirect_url

# Whop “experience” URLs (forum, support, updates) — see docs/WHOP.md
# NEXT_PUBLIC_WHOP_FORUM_URL=https://whop.com/joined/...
# NEXT_PUBLIC_WHOP_SUPPORT_CHAT_URL=https://whop.com/joined/...
# NEXT_PUBLIC_WHOP_PRODUCT_UPDATES_URL=https://whop.com/joined/...

# Whop checkout links (optional). Defaults match plan IDs baked into code.
# Trial: must point to a plan that has a FREE TRIAL set in Whop, or checkout will charge immediately.
# NEXT_PUBLIC_WHOP_CHECKOUT_TRIAL=https://whop.com/checkout/plan_8LkmfefKiGRTz
# NEXT_PUBLIC_WHOP_CHECKOUT_MONTHLY=https://whop.com/checkout/plan_fumKSodpl3C1q
# NEXT_PUBLIC_WHOP_CHECKOUT_QUARTERLY=https://whop.com/checkout/plan_TrJJ6gTzRWKaj
# NEXT_PUBLIC_WHOP_CHECKOUT_ANNUAL=https://whop.com/checkout/plan_8s0HW4fAnAolI

# Whop server (never expose WHOP_API_KEY or SUPABASE_SERVICE_ROLE_KEY to the client)
# WHOP_API_KEY=
# WHOP_WEBHOOK_SECRET=   # raw signing secret from Whop (e.g. ws_...); code base64-encodes for the SDK
# WHOP_PRODUCT_ID=prod_n4pIDJRqfBUx0
# SUPABASE_SERVICE_ROLE_KEY=   # required for POST /api/webhooks/whop to upsert whop_entitlements

# Local dev only: bypass subscription gate (do not set in production)
# WHOP_SKIP_SUBSCRIPTION_GATE=true

# Landing page “Contact us” modal → email (Resend: https://resend.com )
# RESEND_API_KEY=re_...
# CONTACT_INBOX_EMAIL=you@yourdomain.com
# Verified sender in Resend (production). Dev may use onboarding@resend.dev for testing.
# CONTACT_FROM_EMAIL=Echt <onboarding@resend.dev>
